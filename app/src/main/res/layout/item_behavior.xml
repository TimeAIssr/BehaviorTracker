<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/card_behavior"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:checkable="false"
    android:clickable="true"
    android:focusable="true"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeWidth="1dp"
    app:strokeColor="?attr/colorOutlineVariant"
    style="@style/Widget.Material3.CardView.Outlined">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Color indicator -->
        <View
            android:id="@+id/view_color_indicator"
            android:layout_width="8dp"
            android:layout_height="48dp"
            android:background="@color/md_theme_light_primary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/text_behavior_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="?attr/colorOnSurface" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/text_behavior_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorOnSurfaceVariant" />

        </LinearLayout>

        <!-- Quick log button for boolean type -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_quick_log_boolean"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:checkable="true"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:visibility="gone"
            app:cornerRadius="24dp"
            app:icon="@android:drawable/checkbox_off_background"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal" />

        <!-- Quick log button for numeric type -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_quick_log_numeric"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:visibility="gone"
            app:cornerRadius="24dp"
            app:icon="@android:drawable/ic_input_add"
            app:iconGravity="textStart"
            app:iconPadding="0dp"
            style="@style/Widget.Material3.Button.IconButton.Filled.Tonal" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
